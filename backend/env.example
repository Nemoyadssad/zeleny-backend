# Скопируйте этот файл в .env и заполните значения.
# .env НИКОМУ не показывайте и не выкладывайте в открытый доступ.

# Порт, на котором работает сервер
PORT=8080

# Длинная случайная строка для подписи токенов входа (придумайте свою, 40+ символов)
JWT_SECRET=ЗАМЕНИТЕ_на_длинную_случайную_строку

# Ключ Anthropic API для ИИ-объяснений (получается в консоли Anthropic)
ANTHROPIC_API_KEY=

# Секрет для проверки подписи вебхука оплаты (берётся в кабинете платёжной системы)
PAYMENT_WEBHOOK_SECRET=

# Длинный секретный токен администратора (для /api/stats и ручной выдачи доступа)
ADMIN_TOKEN=ЗАМЕНИТЕ_на_длинный_секрет

# Домен(ы) вашего сайта, которым разрешены запросы. Через запятую. Для теста можно *
ALLOWED_ORIGIN=https://ваш-домен.ru

# Модель ИИ (haiku — дешевле и быстрее; можно поставить claude-sonnet-4-6 для более развёрнутых ответов)
AI_MODEL=claude-haiku-4-5-20251001

# Имя файла базы данных
DB_PATH=data.json

# Если хотите отдавать сайт с этого же сервера — путь к папке с index.html. Иначе оставьте пустым.
SERVE_STATIC=
